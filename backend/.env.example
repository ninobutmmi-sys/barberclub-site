# ============================================
# BarberClub API - Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# JWT Authentication
JWT_SECRET=your-secret-key-minimum-256-bits-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-256-bits-change-this

# CORS - Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Brevo (Email + SMS)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=noreply@barberclub-grenoble.fr
BREVO_SENDER_NAME=BarberClub Meylan
BREVO_SMS_SENDER=BARBERCLUB

# Google Reviews
GOOGLE_REVIEW_URL=https://g.page/r/YOUR_GOOGLE_PLACE_ID/review

# Salon Info
SALON_NAME=BarberClub Meylan
SALON_ADDRESS=26 Av. du Grésivaudan, 38700 Corenc
SALON_PHONE=+33xxxxxxxxx
