{
  "name": "barberclub-api",
  "version": "1.0.0",
  "description": "BarberClub Meylan - Booking system API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "NODE_ENV=test jest --runInBand --forceExit --detectOpenHandles",
    "test:unit": "NODE_ENV=test jest tests/unit --forceExit --detectOpenHandles",
    "test:integration": "NODE_ENV=test jest tests/integration --runInBand --forceExit --detectOpenHandles",
    "test:watch": "NODE_ENV=test jest --watch --forceExit --detectOpenHandles",
    "lint": "eslint src/",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "winston": "^3.17.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
